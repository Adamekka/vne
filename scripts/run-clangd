#!/usr/bin/env bash
set -euo pipefail

query_drivers='/nix/store/*/bin/clang++,/opt/homebrew/opt/llvm/bin/clang++'

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

compile_commands_dir=''
if [ -f "${repo_root}/build/compile_commands.json" ]; then
    compile_commands_dir="${repo_root}/build"
fi

clangd_args=("--query-driver=${query_drivers}")
if [ -n "${compile_commands_dir}" ]; then
    clangd_args+=("--compile-commands-dir=${compile_commands_dir}")
fi

if [ -n "${IN_NIX_SHELL:-}" ] && command -v clangd >/dev/null 2>&1; then
    exec clangd "${clangd_args[@]}" "$@"
fi

if command -v nix >/dev/null 2>&1; then
    exec nix develop "path:${repo_root}" --command clangd "${clangd_args[@]}" "$@"
fi

if command -v clangd >/dev/null 2>&1; then
    exec clangd "${clangd_args[@]}" "$@"
fi

printf 'error: clangd is not on PATH and nix is unavailable\n' >&2
exit 1
